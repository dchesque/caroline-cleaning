# ============================================
# chesque PREMIUM CLEANING - PRODUCTION ENVIRONMENT
# ============================================

# ============================================
# SUPABASE (Obrigatório)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# APP (Obrigatório)
# ============================================
NEXT_PUBLIC_APP_URL=https://chesquecleaning.com
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ============================================
# N8N WEBHOOKS (Obrigatório para automações)
# ============================================
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://seu-n8n.com/webhook
N8N_WEBHOOK_SECRET=seu-secret-seguro-aqui

# ============================================
# CAROL AI
# ============================================
OPENROUTER_API_KEY=sua-chave-aqui
CAROL_DEFAULT_MODEL=google/gemini-2.5-flash

# ============================================
# CHAT MODE
# ============================================
# "full"  → agente Carol completo (agendamento, FAQ, cancelamento)
# "lead"  → modo simplificado de captura de lead (nome + telefone + CEP)
NEXT_PUBLIC_CHAT_MODE=lead

# ============================================
# EVOLUTION API (Required for admin WhatsApp notifications)
# ============================================
# Without these, notifyAdmins() is a silent no-op — no new-lead alerts will fire.
EVOLUTION_API_URL=https://evolution.yourdomain.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=caroline-admin
# Catch-all admin number (digits only, no +). Always receives notifications.
EVOLUTION_ADMIN_PHONE=15551234567

# ============================================
# ANALYTICS (Opcional)
# ============================================
# Business Contact Info
NEXT_PUBLIC_BUSINESS_PHONE=(803) 792-1351
NEXT_PUBLIC_BUSINESS_SMS_LINK=sms:+18037921351
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
