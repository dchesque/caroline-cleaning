# ============================================
# CHESQUE PREMIUM CLEANING - ENVIRONMENT
# ============================================
# Copy this file to .env.local (dev) or .env (prod) and fill in real values.

# ============================================
# SUPABASE (Required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# APP (Required)
# ============================================
NEXT_PUBLIC_APP_URL=https://chesquecleaning.com
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ============================================
# CAROL AI (Required)
# ============================================
# OpenRouter API key for Carol AI (LLM gateway)
OPENROUTER_API_KEY=sua-chave-aqui
CAROL_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# SECURITY & CRON (Required in Production)
# ============================================
# Long random string. Protects cron endpoints and internal server-to-server calls
# (reminders, recurrences, cleanup-logs, notifications, tracking events).
CRON_SECRET=seu-segredo-aqui

# ============================================
# TWILIO (Required for SMS/WhatsApp notifications)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Owner phone that receives operational alerts (new bookings, failures, etc.)
OWNER_PHONE_NUMBER=+1xxxxxxxxxx

# ============================================
# N8N WEBHOOK (Optional - external automation)
# ============================================
# Public URL of the n8n webhook that receives outbound events from the app
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://seu-n8n.com/webhook/carolinas
# HMAC/shared secret validated on inbound n8n -> app webhook calls
N8N_WEBHOOK_SECRET=gere-um-secret-seguro-aqui

# ============================================
# OBSERVABILITY & ANALYTICS (Optional)
# ============================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
SENTRY_DSN=https://...
