# ============================================
# CAROLINE PREMIUM CLEANING - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development
# Copy to .env for production (or set in Easypanel)

# ============================================
# SUPABASE CONFIGURATION (Required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# APP CONFIGURATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:8080
NODE_ENV=development
PORT=8080
HOSTNAME=0.0.0.0

# ============================================
# N8N CONFIGURATION (Optional - for Chat & Webhooks)
# ============================================
N8N_WEBHOOK_SECRET=your-webhook-secret
N8N_CHAT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chat

# ============================================
# EVOLUTION API (Optional - for WhatsApp)
# ============================================
EVOLUTION_API_URL=https://evolution-api.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE=caroline

# ============================================
# AI CONFIGURATION (Optional)
# ============================================
OPENAI_API_KEY=sk-...

# ============================================
# ANALYTICS & MONITORING (Optional)
# ============================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
SENTRY_DSN=https://...
