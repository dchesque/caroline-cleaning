# ============================================
# CHESQUE PREMIUM CLEANING - ENVIRONMENT
# ============================================
# Copy this file to .env.local (dev) or .env (prod) and fill in real values.

# ============================================
# SUPABASE (Required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# APP (Required)
# ============================================
NEXT_PUBLIC_APP_URL=https://chesquecleaning.com
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ============================================
# CAROL AI (Required)
# ============================================
# OpenRouter API key for Carol AI (LLM gateway)
OPENROUTER_API_KEY=your-openrouter-key-here
# LLM model used by Carol. Any OpenRouter-compatible model works.
# Recommended: google/gemini-2.5-flash (fast + cheap) or anthropic/claude-3.5-sonnet (highest quality)
CAROL_DEFAULT_MODEL=google/gemini-2.5-flash

# ============================================
# CHAT MODE (Optional — defaults to "full")
# ============================================
# Controls which chat experience is shown to visitors.
#
#   "full"  → Full Carol AI agent: booking, cancellation, FAQ, rescheduling
#   "lead"  → Lead capture only: Carol collects name + phone + ZIP, then a
#             team member follows up to schedule the first evaluation visit.
#             Zero booking logic, lower LLM cost per session.
#
# For production, set to "lead" until the full agent is ready to go live.
# To promote the full agent: change this to "full" and redeploy — no code changes needed.
NEXT_PUBLIC_CHAT_MODE=full

# ============================================
# SECURITY & CRON (Required in Production)
# ============================================
# Long random string. Protects cron endpoints and internal server-to-server calls
# (reminders, recurrences, cleanup-logs, notifications, tracking events).
CRON_SECRET=generate-a-strong-secret-here

# ============================================
# TWILIO (Required for SMS/WhatsApp notifications)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Owner phone that receives operational alerts (new bookings, failures, etc.)
OWNER_PHONE_NUMBER=+1xxxxxxxxxx

# ============================================
# N8N WEBHOOK (Optional - external automation)
# ============================================
# Public URL of the n8n webhook that receives outbound events from the app
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n.com/webhook/carolinas
# HMAC/shared secret validated on inbound n8n -> app webhook calls
N8N_WEBHOOK_SECRET=generate-a-strong-secret-here

# ============================================
# EVOLUTION API (Optional - internal WhatsApp admin notifications)
# ============================================
# Self-hosted Evolution API base URL (no trailing slash)
EVOLUTION_API_URL=https://evolution.yourdomain.com
# API key configured in your Evolution instance
EVOLUTION_API_KEY=your-evolution-api-key
# Instance name you created in Evolution (QR-scanned WhatsApp number)
EVOLUTION_INSTANCE_NAME=caroline-admin
# Catch-all admin number that always receives notifications (no + prefix, e.g. 15551234567)
# For a group JID use the format: 123456789-1234567890@g.us
EVOLUTION_ADMIN_PHONE=15551234567

# ============================================
# OBSERVABILITY & ANALYTICS (Optional)
# ============================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
SENTRY_DSN=https://...
