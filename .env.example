# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# N8n Configuration (Optional - for Chat & Webhooks)
N8N_WEBHOOK_SECRET=your-webhook-secret
N8N_CHAT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chat

# Evolution API (Optional - for WhatsApp)
EVOLUTION_API_URL=https://evolution-api.com
EVOLUTION_API_KEY=your-api-key
EVOLUTION_INSTANCE=caroline

# Analytics & Monitoring (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
SENTRY_DSN=https://...
OPENAI_API_KEY=sk-...
