# ============================================
# chesque PREMIUM CLEANING - ENVIRONMENT
# ============================================

# ============================================
# SUPABASE (Obrigatório)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================
# APP (Obrigatório)
# ============================================
NEXT_PUBLIC_APP_URL=https://chesquecleaning.com
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ============================================
# CAROL AI (Nativo)
# ============================================
OPENROUTER_API_KEY=sua-chave-aqui
CAROL_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# SEGURANÇA E CRON (Obrigatório para Produção)
# ============================================
# Chave para proteger os endpoints de cron (Lembretes)
# Use uma string longa e aleatória
CRON_SECRET=seu-segredo-aqui

# ============================================
# TWILIO (Notificações)
# ============================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
OWNER_PHONE_NUMBER=+1xxxxxxxxxx

# ============================================
# ANALYTICS (Opcional)
# ============================================
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_BUSINESS_PHONE=(551) 389-7394
NEXT_PUBLIC_BUSINESS_SMS_LINK=sms:+15513897394
SENTRY_DSN=https://...
